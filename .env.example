# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com → Project Settings → API

# Public (client-safe) — exposed to browser bundle via NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (never expose to client) — used by admin/service-role client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Database connection pooling (use Supabase pooler for serverless/Vercel)
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
